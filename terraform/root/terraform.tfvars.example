# Canonical infrastructure configuration.
# Local .env and GitHub Actions settings should mirror the subset of values they need from here.
project_id                   = "your-gcp-project-id"
region                       = "your-gcp-region"
raw_dataset_id               = "raw"
stg_dataset_id               = "stg"
int_dataset_id               = "int"
mart_dataset_id              = "mart"
raw_bucket_name              = "your-project-raw-bucket"
artifact_registry_repository = "your-artifact-registry-repository"
ingestion_job_name           = "ingestion-job"
ingestion_image_name         = "ingestion-image"
dbt_job_name                 = "dbt-job"
dbt_target                   = "prod"
dbt_image_name               = "dbt-image"
github_owner                 = "your-github-owner"
github_repository            = "your-github-repository"
github_wif_pool_id           = "github-actions"
github_wif_provider_id       = "github-actions"
ingestion_service_account_id = "sa-ingestion"
dbt_service_account_id       = "sa-dbt"
ci_service_account_id        = "sa-github-ci"
deploy_service_account_id    = "sa-github-deploy"
